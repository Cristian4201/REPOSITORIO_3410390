Algoritmo AreaAmbiente
	// Ej6. Calcular area de sistemas 1
	
	//1. DEFINICION
	Definir largo Como Real;
	Definir ancho Como Real;
	Definir area Como Real;
	
	Escribir "ingrese el largo del ambiente";
	Leer largo;
	Escribir "ingrese el ancho del ambiente";
	Leer ancho;
	area <- largo * ancho;
	
	Escribir "El area del ambiente es ", area;
	
FinAlgoritmo
