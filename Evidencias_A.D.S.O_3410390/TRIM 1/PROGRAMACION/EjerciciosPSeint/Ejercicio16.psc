Algoritmo Ejercicio16
	//Calcular el área de un rectángulo de lados X e Y.
	
	//definicion de variables
	Definir area como real;
	Definir ladoX como real;
	Definir ladoY como real;
	
	//Asignacion de variables
	Escribir "Ingrese el valor del lado x";
	Leer ladoX;
	Escribir "Ingrese el valor del lado y";
	Leer ladoY;
	
	//Proceso 
	area <- ladoX * ladoY;
	
	//salida
	Escribir "El área de su rectángulo es de: ", area;
	
FinAlgoritmo
