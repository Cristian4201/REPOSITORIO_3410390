Algoritmo Ejercicio8
	//CRISTIAN BENAVIDES
	//8. Hacer un algoritmo que lea el nombre de una persona y numero de horas que estudia a la semana
	
	//Definicion de variables
	Definir Nombre como cadena;
	Definir Horas Como Real;
	
	//entrada
	Escribir "Digite el nombre de la persona";
	Leer Nombre;
	Escribir "Ingrese el numero de horas que estudia a la semana";
	Leer Horas;
	
	//salida
	Escribir "El nombre es ",Nombre, " y las horas que trabaja a la semana son: ",Horas;
FinAlgoritmo
