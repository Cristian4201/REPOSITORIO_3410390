Algoritmo Ejercicio13
	//Pedir el radio de un círculo y calcular su área.
	//A=PI*r^2.
	
	//definicion de variables
	Definir Radio como real;
	Definir Area como real;
	
	//Entrada
	Escribir "Digite el radio de su círculo";
	Leer Radio;
	
	//Proceso 
	Area<-PI*Radio^2;
	
	//salida
	Escribir "El área de su circulo es de: ",Area;
	
FinAlgoritmo
