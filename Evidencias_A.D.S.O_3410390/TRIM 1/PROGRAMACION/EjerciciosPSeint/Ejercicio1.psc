Algoritmo Ejercicio1
	//CRISTIAN BENAVIDES
	//1. Hacer un algoritmo que declare una variable para guardar el número de horas de estudio, y otra para guardar el nombre. Escribir ambos datos.
	
	//ENTRADA
	//DEFINICION
	Definir horasEstudio Como Entero;
	Definir nombre Como Cadena;
	
	//ASIGNACION
	horasEstudio <- 5;
	nombre <- "Juan";
	
	//SALIDA
	Escribir "Nombre ", nombre;
	Escribir "Horas de estudio ", horasEstudio;
FinAlgoritmo
