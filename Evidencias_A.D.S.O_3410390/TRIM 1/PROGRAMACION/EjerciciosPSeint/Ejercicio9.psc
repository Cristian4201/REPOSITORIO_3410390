Algoritmo Ejercicio9
	//CRISTIAN BENAVIDES
	//9. Hacer un algoritmo que lea el nombre de un estudiante, la cantidad de materias perdidas y la cantidad de materias ganadas.
	
	//Definicion de variables
	Definir NombreEstudiante Como cadena;
	Definir MateriasPerdidas como entero;
	Definir MateriasGanadas como entero;
	
	//entrada
	Escribir "Digite su Nombre, la cantidad de materias ganadas y la cantidad de materias perdidas";
	Leer NombreEstudiante, MateriasGanadas, MateriasPerdidas;
	
	//salida
	Escribir "Su nombre es ",NombreEstudiante, " la cantidad de materias ganadas son ", MateriasGanadas, " y la cantidad de materias perdidas son ", MateriasPerdidas;
FinAlgoritmo
