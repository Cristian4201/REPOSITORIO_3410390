Algoritmo Ejercicio2
	//CRISTIAN BENAVIDES
	//2. Hacer un algoritmo que lea dos números enteros A y B y muestre el doble de su suma.
	
	//ENTRADA
	//DEFINICION
	Definir numA, numB, resultado Como Entero;
	
	//ASIGNACION
	Escribir "Ingrese el número A:";
    Leer numA;
    Escribir "Ingrese el número B:";
    Leer numB;
	
	//PROCESO
	resultado <- (numA + numB) * 2;
	
	//SALIDA
	Escribir "El doble de la suma es: ", resultado;
FinAlgoritmo
