Algoritmo Ejercicio11
	//Hacer un algoritmo que lea dos números enteros A y B
	//y muestre su diferencia.
	
	//Definicion de variables
	Definir NumeroA como entero;
	Definir NumeroB como entero;
	Definir Diferencia como entero;
	
	//Entrada
	Escribir "Digire su número A y su número B";
	Leer NumeroA, NumeroB;
	
	//Proceso 
	Diferencia<- NumeroA-NumeroB;
	
	//salida
	Escribir "La diferencia entre los dos números es de: ", Diferencia;
	
FinAlgoritmo
