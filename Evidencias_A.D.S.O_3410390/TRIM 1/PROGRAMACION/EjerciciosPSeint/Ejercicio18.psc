Algoritmo Ejercicio18
	//Pedir un nºmero e indicar si es positivo o negativo.
	
	//Definicion de variables
	Definir Num como real;
	
	//Entrada
	Escribir "Digite un nºmero";
	Leer Num;
	//Proceso 
	Si num <0 Entonces
		Escribir "Su nºmero es negativo";
	Sino
		Escribir " Su nºmero es positivo";
	FinSi
FinAlgoritmo
