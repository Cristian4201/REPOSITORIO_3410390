Algoritmo Ejercicio15
	//Pedir el lado de un cuadrado, mostrar su área y su perímetro.
	
	//Definicion de variables
	Definir Lado como real;
	Definir Area como real;
	Definir Perimetro como real;
	
	//entrada
	Escribir "Digite el lado de su cuadrado";
	Leer Lado;
	
	//Proceso 
	Area<-Lado^2;
	Perimetro<-Lado*4;
	
	//salida
	Escribir "El área de su cuadrado es de ",Area, " y su perimetro es de ",Perimetro;
	
	
FinAlgoritmo
