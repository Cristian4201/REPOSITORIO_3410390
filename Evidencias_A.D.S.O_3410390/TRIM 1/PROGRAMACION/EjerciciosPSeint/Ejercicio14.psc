Algoritmo Ejercicio14
	//Pedir el radio de una circunferencia y calcular su longitud.
	
	//Definicion de variables
	Definir Radio como real;
	Definir Longiitud como real;
	
	//entrada
	Escribir "Digite el radio de su circunferencia";
	Leer Radio;
	
	//Proceso 
	Longiitud<-2*PI*Radio;
	
	//salida
	Escribir "La longitud de su circunferencia es de: ",Longiitud;
	
	
FinAlgoritmo
